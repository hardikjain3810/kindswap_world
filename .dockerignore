.env
.env.*
*.env

# Test files
**/*.test.ts
**/*.spec.ts
**/__tests__

# IDE
.vscode
.idea
*.swp

# OS
.DS_Store
Thumbs.db

# Terraform
infra/
*.tfstate
*.tfvars

# CI/CD
.github/

# Documentation
*.md
docs/

# Docker files themselves (optional)
Dockerfile
docker-compose.yml
.dockerignore
