# KindSwap Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# SENTRY CONFIGURATION (Error Tracking)
# ============================================

# Sentry DSN - Data Source Name (public key for sending errors to Sentry)
# Get from: Sentry Dashboard → Settings → Projects → kindswap-frontend → Client Keys (DSN)
# IMPORTANT: This is a PUBLIC key (safe to expose in browser)
# Leave empty to disable Sentry (useful for local development)
VITE_SENTRY_DSN=<key_sentry_DSN>

# Sentry Environment - determines error segregation in Sentry dashboard
# Options: 'staging' | 'production'
# IMPORTANT: Set this in your deployment platform (Vercel, Railway, etc.)
# - Staging deployment: VITE_SENTRY_ENVIRONMENT=staging
# - Production deployment: VITE_SENTRY_ENVIRONMENT=production
# - Local development: Leave unset (Sentry auto-disabled on localhost)
VITE_SENTRY_ENVIRONMENT=staging

# App Version - used for release tracking in Sentry
# Update this when deploying new versions
VITE_APP_VERSION=1.0.0

# ============================================
# API KEYS
# ============================================

# Jupiter API Key (get from https://station.jup.ag/docs)
VITE_JUPITER_API_KEY=your_jupiter_api_key_here

# CoinGecko API Keys (get from https://www.coingecko.com/en/api/pricing)
# Multiple keys enable automatic rotation on rate limits (429 errors)
VITE_COINGECKO_API_KEY_1=your_coingecko_api_key_1_here
VITE_COINGECKO_API_KEY_2=your_coingecko_api_key_2_here

# Solana RPC endpoint (for Jupiter swaps and blockchain queries)
# Options: Public Solana RPC (free) or Helius/Triton/QuickNode (paid, better performance)
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Solscan API Token (for fetching holder data, transaction history, etc.)
# Get from: https://pro-api.solscan.io/
SOLSCAN_API_TOKEN=your_solscan_api_token_here

# Backend API URL for swap logging and points tracking
# Required for swap transaction logging to work
VITE_API_BASE_URL=http://localhost:5000

VITE_SINGLE_TX_SWAP_ENABLED=true
