# Application
NODE_ENV=development
PORT=3000

# Solscan API Configuration
# Get your free API key from: https://pro-api.solscan.io/pro-api-portal/account
SOLSCAN_API_KEY=

# CoinGecko API Configuration (OPTIONAL - for higher rate limits)
# Free tier works without API key (10-50 calls/min)
# Get Demo API key from: https://www.coingecko.com/en/api/pricing
# Demo plan: 500 calls/min, Pro plan: 10,000 calls/min
COINGECKO_API_KEY=

SENTRY_DSN=

SENTRY_ENVIRONMENT=staging

# Server name for Sentry context
SERVER_NAME=kindswap-api

# Sentry CLI Configuration (for source maps upload in production builds)
# Get auth token from: https://sentry.io → Settings → Auth Tokens → Create New Token
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kindswap
SENTRY_PROJECT=kindswap-backend
# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Database Connection
# IMPORTANT: Use different databases for internal and client deployments
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=kindsoul_dev

# Database SSL Configuration (production only)
DATABASE_SSL=false

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis for caching and job queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# BLOCKCHAIN / SOLANA CONFIGURATION
# ============================================

# Helius RPC API Key
# Get from: https://www.helius.dev/
HELIUS_API_KEY=your_helius_api_key_here

# Solana RPC Endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# KNS Token Mint Address (Solana)
KNS_TOKEN_MINT=your_kns_token_mint_address

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for CORS (comma-separated list)
# IMPORTANT: Set this to your actual frontend domain(s) in production
# Development: Include localhost ports
# Production: Only include your production domains
ALLOWED_ORIGINS=https://admin.kindswap.world,https://kindswap.world

# Legacy CORS_ORIGIN (deprecated - use ALLOWED_ORIGINS instead)
CORS_ORIGIN=http://localhost:5173

# ============================================
# AUTHENTICATION / SECURITY
# ============================================

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# JWT Expiration (e.g., '1d', '7d', '30d')
JWT_EXPIRATION=7d

# API Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# ADMIN CONFIGURATION
# ============================================

# Super Admin Wallet Address (Solana wallet)
SUPER_ADMIN_WALLET=your_super_admin_wallet_address

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# App Version (sync with package.json)
APP_VERSION=1.0.0

# ============================================
# IMPORTANT NOTES FOR DEPLOYMENT
# ============================================
#
# INTERNAL PRODUCTION (.env.production - internal):
# - DATABASE_HOST=internal-db.kindswap.io
# - DATABASE_NAME=kindsoul_internal_prod
# - REDIS_HOST=internal-redis.kindswap.io
# - CORS_ORIGIN=https://internal.kindswap.io
# - SENTRY_ENVIRONMENT=production-internal
# - SENTRY_DSN=<internal-sentry-dsn>
#
# CLIENT PRODUCTION (.env.production - public):
# - DATABASE_HOST=client-db.kindswap.io
# - DATABASE_NAME=kindsoul_prod
# - REDIS_HOST=client-redis.kindswap.io
# - CORS_ORIGIN=https://kindswap.world
# - SENTRY_ENVIRONMENT=production
# - SENTRY_DSN=<client-sentry-dsn>
#
# NEVER commit actual .env files to Git!
# Configure these in your deployment platform (Railway, Heroku, AWS, etc.)