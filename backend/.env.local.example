# KindSwap Backend - Development Environment Variables
# Copy this to .env.local and adjust values as needed

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://devuser:devpass123@localhost:5432/kindswap_dev
DB_HOST=localhost
DB_PORT=5432
DB_USER=devuser
DB_PASSWORD=devpass123
DB_NAME=kindswap_dev
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_CACHE=true

# ==========================================
# CACHE CONFIGURATION (Redis)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_POINTS=false
ENABLE_REWARDS=false
ENABLE_FEES=true
ENABLE_AUDIT_LOGGING=true

# ==========================================
# SOLANA CONFIGURATION
# ==========================================
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL_FALLBACK=https://devnet.genesysgo.net/
SOLANA_NETWORK=devnet
SOLANA_COMMITMENT=confirmed

# ==========================================
# HELIUS RPC CONFIGURATION
# ==========================================
# Sign up for free at: https://www.helius.dev/
# Free tier includes 100K requests/month - plenty for development
# For devnet development, you can use a free API key
HELIUS_API_KEY=your_helius_free_api_key_here

# ==========================================
# SOLSCAN API CONFIGURATION
# ==========================================
# Optional: Get from https://solscan.io/ (free tier available)
# For development, empty value or placeholder is acceptable
SOLSCAN_API_KEY=your_solscan_api_key_here

# ==========================================
# JWT / AUTHENTICATION
# ==========================================
JWT_SECRET=dev-secret-key-do-not-use-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=dev-refresh-secret-do-not-use-in-production
REFRESH_TOKEN_EXPIRY=7d

# ==========================================
# WALLET VERIFICATION
# ==========================================
WALLET_VERIFICATION_REQUIRED=false
SIGNATURE_VERIFICATION_TIMEOUT=300

# ==========================================
# FEE CONFIGURATION
# ==========================================
BASE_FEE_BPS=10.0
CHARITY_PORTION=0.5
KINDSWAP_PORTION=0.5
FEE_UPDATE_FREQUENCY=86400

# ==========================================
# ADMIN SETTINGS
# ==========================================
ADMIN_WALLET=Admin_Wallet_Address_Here
ADMIN_SECRET=admin-secret-key-change-this

# ==========================================
# EXTERNAL INTEGRATIONS (optional)
# ==========================================
# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# SendGrid (email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@kindswap.dev

# AWS (if using S3, SQS, etc)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================
# DEVELOPMENT DEBUGGING
# ==========================================
DEBUG=kindswap:*
VERBOSE_LOGGING=true
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true

# ==========================================
# DATABASE POOLING
# ==========================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# SECURITY (Development Only)
# ==========================================
ALLOW_INSECURE_HTTP=true
HELMET_ENABLED=false
DISABLE_CSRF=true
