# ============================================================================
# KINDSWAP GITIGNORE — Production-Safe Configuration
# ============================================================================
# Security-Critical: Never commit secrets, credentials, private keys, or state files

# ============================================================================
# 1. ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production.local
.env.production
*.env

# AWS Credentials
.aws/
~/.aws/
AWS_PROFILE=*
AWS_ACCESS_KEY_ID=*
AWS_SECRET_ACCESS_KEY=*

# Private Keys & Certificates
*.key
*.pem
*.pfx
*.p12
*.der
*.crt
*.cert
*.cer
*.p8
id_rsa
id_dsa
*.jks

# SSH Keys
.ssh/
**/ssh/
known_hosts

# Terraform Secrets & State
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log

