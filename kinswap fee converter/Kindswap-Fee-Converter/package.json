{
  "name": "lambda-fee-converter",
  "version": "1.0.0",
  "description": "Automated fee conversion system for KindSwap using AWS Lambda",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:prod": "tsc --project tsconfig.prod.json && tsc-alias -p tsconfig.prod.json",
    "clean": "rimraf dist coverage .serverless",
    "dev": "tsx watch src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testMatch='**/*.integration.test.ts'",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "migrate:up": "node -r dotenv/config dist/migrations/migrate.js up",
    "migrate:down": "node -r dotenv/config dist/migrations/migrate.js down",
    "seed:policy": "node -r dotenv/config dist/migrations/seed-policy.js",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage production",
    "invoke:local": "serverless invoke local",
    "logs": "serverless logs",
    "lambda:fee-indexer": "node test-lambda-direct.js feeIndexer",
    "lambda:conversion-planner": "node test-lambda-direct.js conversionPlanner",
    "lambda:conversion-executor": "node test-lambda-direct.js conversionExecutor",
    "lambda:usdc-distributor": "node test-lambda-direct.js usdcDistributor",
    "lambda:test-all": "npm run lambda:fee-indexer && npm run lambda:conversion-planner && npm run lambda:conversion-executor && npm run lambda:usdc-distributor",
    "docker:build": "docker build -t lambda-fee-converter:latest .",
    "docker:run": "docker-compose up",
    "docker:down": "docker-compose down",
    "prepare": "husky install"
  },
  "keywords": [
    "lambda",
    "aws",
    "serverless",
    "solana",
    "fee-conversion",
    "defi"
  ],
  "author": "KindSoul",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-kms": "^3.699.0",
    "@aws-sdk/client-secrets-manager": "^3.699.0",
    "@aws-sdk/client-sqs": "^3.699.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.11",
    "module-alias": "^2.3.4",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "serverless": "^4.4.14",
    "serverless-esbuild": "^1.54.3",
    "serverless-offline": "^14.4.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
