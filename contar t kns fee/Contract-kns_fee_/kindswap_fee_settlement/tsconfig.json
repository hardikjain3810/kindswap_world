{
  "compilerOptions": {
    "target":          "es2020",
    "module":          "commonjs",
    "strict":          true,
    "esModuleInterop": true,
    "outDir":          "./dist",
    "baseUrl":         ".",
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
